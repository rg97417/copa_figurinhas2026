# ─────────────────────────────────────────────────────────────────
# TEMPLATE DE CONFIGURAÇÃO — Copa Figurinhas
# Copie este arquivo para .env.local e preencha os valores.
# No Vercel: adicione cada variável em Settings > Environment Variables
# ─────────────────────────────────────────────────────────────────

# ── IDENTIDADE DO PROJETO ─────────────────────────────────────────
NEXT_PUBLIC_PROJECT_NAME=Convoca Kids
NEXT_PUBLIC_BASE_URL=https://www.seudominio.com

# ── EMAIL (Resend) ────────────────────────────────────────────────
# Acesso: https://resend.com/signup
# Onde pegar: Resend → API Keys → Create API Key
# Verificar domínio em: Resend → Domains → Add Domain
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=Seu Projeto <contato@seudominio.com>

# ── CHECKOUT / PREÇO ─────────────────────────────────────────────
# Acesso: https://app.kiwify.com.br
# Onde pegar: Kiwify → Produtos → seu produto → link de pagamento
NEXT_PUBLIC_CHECKOUT_URL=https://pay.kiwify.com.br/SEUPRODUTO
NEXT_PUBLIC_PRICE=19,90
NEXT_PUBLIC_PRICE_ORIGINAL=39,90

# ── SUPABASE ──────────────────────────────────────────────────────
# Acesso: https://supabase.com/dashboard
# Onde pegar: Supabase → seu projeto → Settings → API
# Rodar supabase/setup.sql no SQL Editor antes de usar
NEXT_PUBLIC_SUPABASE_URL=https://XXXXXXXXXXX.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
SUPABASE_SERVICE_ROLE_KEY=eyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── OPENAI (gpt-image-2) ──────────────────────────────────────────
# Acesso: https://platform.openai.com/api-keys
# Onde pegar: OpenAI Platform → API Keys → Create new secret key
# Atenção: precisa de créditos — https://platform.openai.com/settings/organization/billing
OPENAI_API_KEY=sk-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── REPLICATE (remoção de fundo) ──────────────────────────────────
# Acesso: https://replicate.com/signin
# Onde pegar: Replicate → Account → API Tokens
# ATENÇÃO: a variável se chama REPLICATE_API_KEY (não TOKEN)
REPLICATE_API_KEY=r8_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── REDIS / UPSTASH (rate limit) ─────────────────────────────────
# Acesso: https://console.upstash.com
# Onde pegar: Upstash → Create Database → Redis → REST API → URL e Token
UPSTASH_REDIS_REST_URL=https://XXXXXXXX.upstash.io
UPSTASH_REDIS_REST_TOKEN=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── IA — REFERÊNCIA E PROMPT ──────────────────────────────────────
# Substitua o arquivo public/assets/jersey_reference.png pela foto do seu atleta
AI_REFERENCE_IMAGE_FILE=jersey_reference.png
# Troque "Neymar" e "Brazil national team jersey" pelo seu atleta e camisa
AI_PROMPT=The first image is Neymar wearing the Brazil national team jersey. The second image is a different person. Replace Neymar with the person from the second image. Keep everything else exactly the same: jersey, pose, framing, lighting and background. Preserve the exact face, skin tone, hair and age from the second image.

# ── WATERMARK ─────────────────────────────────────────────────────
NEXT_PUBLIC_WATERMARK_TEXT=CONVOCA KIDS

# ── ADMIN ────────────────────────────────────────────────────────
# Painel de operações: https://seudominio.com/painel-ops
# Senha para acessar — escolha uma senha forte
ADMIN_SECRET=SUASENHAFORTE

# ── META / FACEBOOK ──────────────────────────────────────────────
# Acesso: https://business.facebook.com/events_manager
# Pixel ID: Events Manager → seu Pixel → Configurações → Pixel ID
NEXT_PUBLIC_META_PIXEL_ID=XXXXXXXXXXXXXXXX
# Token API Conversões: Events Manager → seu Pixel → Configurações → API de Conversões → Gerar token
META_ACCESS_TOKEN=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# Opcional — código de teste: Events Manager → Test Events → Test event code

# ── WEBHOOK KIWIFY ────────────────────────────────────────────────
# Acesso: https://app.kiwify.com.br
# Onde configurar: Kiwify → Configurações → Webhooks
# URL do webhook: https://seudominio.com/api/kiwify/webhook?token=VALOR_ABAIXO
# Use qualquer string aleatória como segredo (ex: openssl rand -hex 24)
KIWIFY_WEBHOOK_SECRET=SEUTOKENWEBHOOK
